{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "./",
    "allowJs": true,
    "checkJs": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": false,
    "types": ["node"],
    "lib": ["ESNext"],
    "isolatedModules": true,
    "resolveJsonModule": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "strictFunctionTypes": true,
    "exactOptionalPropertyTypes": false,
    "noImplicitAny": true,
    "useUnknownInCatchVariables": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@iris/*": ["./source/controller/*"],
      "@iris/logger": ["./source/controller/plugins/console/logger.ts"],
      "@iris/utils": ["./source/controller/plugins/utils.ts"],
      "@iris/logins": ["./source/controller/plugins/login.ts"],
      "@iris/server": ["./source/controller/server.ts"]
    }
  },
  "include": ["**/*.js", "**/*.ts"],
  "exclude": ["node_modules", "dist"]
}